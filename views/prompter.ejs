<!-- views/prompter.ejs -->
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Prompter</title>
    <style>
      body {
        margin: 0;
        padding: 40px;
        box-sizing: border-box;
        background-color: #000;
        color: #fff;
        font-family: "Courier New", Courier, monospace;
        font-size: 5vw; /* Tamaño de fuente relativo al ancho del viewport */
        line-height: 1.2;
        height: 100vh;
        overflow-y: auto; /* Permite scroll si el texto es muy largo */
        transition: background-color 0.4s ease;
        /* white-space: pre-wrap; Respeta los saltos de línea y espacios */
      }
      body.flash {
        background-color: #01aded;
      }
      #text-display {
        transition: text-shadow 0.4s ease, transform 0.4s ease;
      }
      body.flash #text-display {
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.8);
        transform: scale(1.02);
      }
      /* #text-display {
        transform: scaleX(-1) rotate(180deg);
        text-align: left;
        background-color: black;
        color: #fff;
        font-family: Arial, sans-serif;
        font-size: 50px;
        line-height: 1.5;
      } */
      #text-title {
        /* display: none; */
      }
    </style>
  </head>
  <body>
    <h5 id="text-title">Titulo</h5>
    <div id="text-display">Contenido</div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();
      socket.emit("register-route", "prompter");
      const textDisplay = document.getElementById("text-display");
      const textTitle = document.getElementById("text-title");

      function flashHighlight() {
        document.body.classList.add("flash");
        setTimeout(() => {
          document.body.classList.remove("flash");
        }, 400);
      }

      socket.on("text-update", (text) => {
        textDisplay.innerText = `${text}\n\n\n`;
        flashHighlight();
        console.log("Texto actualizado.");
      });
      socket.on("title-update", (text) => {
        textTitle.innerText = text;
        console.log("Titulo actualizado.");
      });
    </script>
  </body>
</html>
