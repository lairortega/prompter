<!-- views/image.ejs -->
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Visor de Imagen</title>
    <style>
      body {
        margin: 0;
        background-color: #000;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        overflow: hidden;
      }
      #image-container {
        position: relative;
        width: 100vw;
        height: 100vh;
      }
      img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        opacity: 0;
        transition: opacity 1s ease-in-out;
      }
      img.visible {
        opacity: 1;
      }
    </style>
  </head>
  <body>
    <div id="image-container"></div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
      const socket = io();
      const container = document.getElementById("image-container");

      socket.on("image-update", (newImagePath) => {
        const url = newImagePath + "?t=" + new Date().getTime();
        const newImg = document.createElement("img");
        newImg.src = url;

        newImg.onload = () => {
          container.appendChild(newImg);
          // Forzar reflow para asegurar la transición
          void newImg.offsetWidth;
          newImg.classList.add("visible");

          const oldImages = container.querySelectorAll("img:not(:last-child)");
          oldImages.forEach((img) => {
            img.classList.remove("visible");
            setTimeout(() => {
              if (img.parentNode) img.parentNode.removeChild(img);
            }, 1000);
          });
        };
        console.log("Ruta de imagen recibida:", newImagePath);
      });
    </script>
  </body>
</html>
